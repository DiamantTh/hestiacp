#!/bin/bash
# info: add a WebAuthn passkey credential to a user account
# options: USER CREDENTIAL_ID PUBLIC_KEY_PEM SIGN_COUNT NAME
#
# example: v-add-user-passkey admin "base64id" "-----BEGIN PUBLIC KEY-----..." 0 "My YubiKey"
#
# This function stores a new WebAuthn/FIDO2 passkey credential for the user.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
credential_id=$2
public_key_pem=$3
sign_count=$4
name=$5

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '5' "$#" 'USER CREDENTIAL_ID PUBLIC_KEY_PEM SIGN_COUNT NAME'
is_format_valid 'user' 'system'
is_object_valid 'user' 'USER' "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

passkey_file="$USER_DATA/passkeys.json"
timestamp=$(date '+%Y-%m-%d %T')

# Escape values for JSON
escaped_id=$(echo "$credential_id" | sed 's/\\/\\\\/g; s/"/\\"/g')
escaped_key=$(echo "$public_key_pem" | sed 's/\\/\\\\/g; s/"/\\"/g; s/$/\\n/g' | tr -d '\n')
escaped_key="${escaped_key%\\n}"
escaped_name=$(echo "$name" | sed 's/\\/\\\\/g; s/"/\\"/g')

new_entry="{\"id\":\"${escaped_id}\",\"public_key\":\"${escaped_key}\",\"sign_count\":${sign_count},\"name\":\"${escaped_name}\",\"created\":\"${timestamp}\",\"last_used\":\"\"}"

if [ -f "$passkey_file" ]; then
	# Append new credential to existing JSON object
	# Remove the trailing } and add new entry
	existing=$(cat "$passkey_file")
	# Check if credential already exists
	if echo "$existing" | grep -q "\"${escaped_id}\""; then
		echo "Error: Passkey credential already exists"
		exit "$E_EXISTS"
	fi
	updated=$(echo "$existing" | sed 's/}[[:space:]]*$//')
	if [ "$updated" = "{" ]; then
		echo "{\"${escaped_id}\":${new_entry}}" >"$passkey_file"
	else
		echo "${updated},\"${escaped_id}\":${new_entry}}" >"$passkey_file"
	fi
else
	echo "{\"${escaped_id}\":${new_entry}}" >"$passkey_file"
fi

chmod 600 "$passkey_file"
chown "$user:$user" "$passkey_file" 2>/dev/null || true

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "Security" "WebAuthn passkey added (User: $user, Name: $name)."
$BIN/v-log-action "$user" "Info" "Security" "WebAuthn passkey added (Name: $name)."
log_event "$OK" "$ARGUMENTS"

exit
