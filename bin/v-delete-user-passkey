#!/bin/bash
# info: delete a WebAuthn passkey credential from a user account
# options: USER CREDENTIAL_ID
#
# example: v-delete-user-passkey admin "base64credentialid"
#
# This function removes a stored WebAuthn/FIDO2 passkey credential for the user.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
credential_id=$2

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER CREDENTIAL_ID'
is_format_valid 'user' 'system'
is_object_valid 'user' 'USER' "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

passkey_file="$USER_DATA/passkeys.json"

if [ ! -f "$passkey_file" ]; then
	echo "Error: No passkeys registered for user"
	exit "$E_NOTEXIST"
fi

# Use PHP to safely remove the credential from the JSON file
result=$($HESTIA_PHP -r "
\$file = '$passkey_file';
\$id = '$credential_id';
\$data = json_decode(file_get_contents(\$file), true);
if (!isset(\$data[\$id])) {
    echo 'NOTEXIST';
    exit(1);
}
unset(\$data[\$id]);
file_put_contents(\$file, json_encode(\$data, JSON_PRETTY_PRINT));
echo 'OK';
")

if [ "$result" = "NOTEXIST" ]; then
	echo "Error: Passkey credential not found"
	exit "$E_NOTEXIST"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Warning" "Security" "WebAuthn passkey removed (User: $user)."
$BIN/v-log-action "$user" "Warning" "Security" "WebAuthn passkey removed."
log_event "$OK" "$ARGUMENTS"

exit
